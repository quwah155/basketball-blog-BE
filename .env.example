# Backend Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your .env file to version control.

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────

# Environment: development | production
NODE_ENV=development

# Port the Express server listens on
PORT=5000

# Frontend origin allowed by CORS (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.example.mongodb.net/basketballblog?appName=Cluster0

# ─────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────

# Secret key for signing JWTs — use a long, random string (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ─────────────────────────────────────────
# EMAIL (Nodemailer via Gmail)
# ─────────────────────────────────────────

# Gmail address used to send OTP verification emails
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your normal login password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─────────────────────────────────────────
# ADMIN ACCOUNT (used by seedAdmin.js only)
# ─────────────────────────────────────────

# Email for the initial admin account
ADMIN_EMAIL=admin@yourdomain.com

# Password for the initial admin account (change after first login)
ADMIN_PASSWORD=YourSecureAdminPassword!

# ─────────────────────────────────────────
# EXTERNAL APIs
# ─────────────────────────────────────────

# BallDontLie NBA API key — https://www.balldontlie.io/
# Used by liveController to fetch today's NBA game scores.
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here
